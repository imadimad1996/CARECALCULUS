{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "favicons": "tsx scripts/generate-favicons.ts",
    "llmstxt": "tsx scripts/generate-llmstxt.ts",
    "build": "npm run favicons && npm run sitemap && npm run llmstxt && vite build && node scripts/postbuild-rtl.mjs",
    "og": "tsx scripts/generate-og.tsx",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=carecalculus",
    "deploy:ci": "wrangler pages deploy dist --project-name=carecalculus --commit-dirty=true",
    "ping-sitemap": "curl -s \"https://www.google.com/ping?sitemap=https://carecalculus.com/sitemap.xml\" && curl -s \"https://www.bing.com/ping?sitemap=https://carecalculus.com/sitemap.xml\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.16.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.17.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "pdf-parse": "^1.1.1",
    "satori": "^0.26.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-prerender-plugin": "^0.5.13",
    "wrangler": "^4.100.0"
  }
}
